<launch>
  <!-- 1. 发布静态 TF 变换：world 坐标系 -> map 坐标系 -->
  <!-- 参数说明：x y z roll pitch yaw 父坐标系 子坐标系 发布频率(Hz) -->
  <node pkg="tf" type="static_transform_publisher" name="world_to_map" 
        args="0 0 0.0 0 0 0 world map 10" />

  <!-- 2. 发布静态 TF 变换：base_link 坐标系 -> usb_cam 坐标系 -->
  <!-- 参数说明：x y z roll pitch yaw (单位：米/弧度)，这里设置了相机相对于底座的位置和旋转 -->
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_cam" 
        args="0 0 0.3 0 1.57 -1.57 base_link usb_cam 10" />

  <!-- 3. 定义可配置参数（可在启动时通过命令行覆盖） -->
  <arg name="marker_size" default="9" />           <!-- AR 标签的实际尺寸（单位：厘米） -->
  <arg name="max_new_marker_error" default="0.08" /><!-- 新检测到的标签允许的最大误差 -->
  <arg name="max_track_error" default="0.2" />     <!-- 跟踪过程中允许的最大误差 -->
  <arg name="cam_image_topic" default="/usb_cam/image_raw" /> <!-- 摄像头图像话题 -->
  <arg name="cam_info_topic" default="/usb_cam/camera_info" /> <!-- 摄像头参数话题 -->
  <arg name="output_frame" default="/usb_cam" />    <!-- 输出结果的坐标系 -->


  
  
  <!-- 4. 启动 AR 标签识别节点 (ar_track_alvar) -->
  <node name="ar_track_alvar" pkg="ar_track_alvar" type="individualMarkersNoKinect" 
        respawn="false" output="screen">
    <!-- 将参数传递给节点 -->
    <param name="marker_size" type="double" value="$(arg marker_size)" />
    <param name="max_new_marker_error" type="double" value="$(arg max_new_marker_error)" />
    <param name="max_track_error" type="double" value="$(arg max_track_error)" />
    <param name="output_frame" type="string" value="$(arg output_frame)" />
    
    <!-- 话题重映射：将节点默认的输入话题映射到实际的摄像头话题 -->
    <remap from="camera_image" to="$(arg cam_image_topic)" />
    <remap from="camera_info" to="$(arg cam_info_topic)" />
  </node>

  <node name="cam_info_relay" pkg="topic_tools" type="relay" args="/camera_info /usb_cam/camera_info" />


  <!-- 5. 启动 RViz 可视化工具 -->
  <!-- args="-d ..." 指定加载预存的 RViz 配置文件 -->
  <node pkg="rviz" type="rviz" name="rviz" 
        args="-d $(find track_tag)/rviz/ar_track_camera.rviz" />
</launch>